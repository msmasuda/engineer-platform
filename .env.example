# Vercel Postgres (PostgreSQL)
# Prisma で接続プール（プール接続）を利用する場合に使用
POSTGRES_PRISMA_URL="postgresql://postgres:password@localhost:5432/postgres?pgbouncer=true&connect_timeout=15"
# Prisma で直接接続（マイグレーション用など）を利用する場合に使用
POSTGRES_URL_NON_POOLING="postgresql://postgres:password@localhost:5432/postgres?connect_timeout=15"

# Vercel KV (Redis)
KV_URL="redis://localhost:6379"
KV_REST_API_URL="https://localhost:8079"
KV_REST_API_TOKEN="mock_token"
KV_REST_API_READ_ONLY_TOKEN="mock_read_only_token"

# Auth.js (NextAuth.js)
# `npx auth secret` または `openssl rand -base64 33` などで生成した秘密鍵を設定
AUTH_SECRET="your-auth-secret-minimum-32-characters"

# NextAuth URL (Vercelデプロイ時は不要、ローカル開発時に必要になる場合があります)
# NEXTAUTH_URL="http://localhost:3000"

# OAuth Providers (GitHub, Google, Apple)
AUTH_GITHUB_ID="your-github-client-id"
AUTH_GITHUB_SECRET="your-github-client-secret"

AUTH_GOOGLE_ID="your-google-client-id"
AUTH_GOOGLE_SECRET="your-google-client-secret"

AUTH_APPLE_ID="your-apple-client-id"
AUTH_APPLE_SECRET="your-apple-client-secret"
